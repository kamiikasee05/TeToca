      {
        "id": "filter-tomorrow",
        "name": "Filtrar turnos de ma+�ana",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [
          850,
          300
        ],
        "parameters": {
          "jsCode": "const tomorrow = new Date();\ntomorrow.setDate(tomorrow.getDate() + 1);\nconst dateStr = tomorrow.toISOString().split('T')[0];\n\nconst bookings = $input.all();\nconst filtered = bookings.filter(b => {\n  const start = b.json.start;\n  return start && start.startsWith(dateStr);\n});\n\nif (filtered.length === 0) {\n  return [{ json: { empty: true } }];\n}\nreturn filtered.map(b => {\n  const cust = b.json.customer || {};\n  const serv = b.json.service || {};\n  const prov = b.json.provider || {};\n  const startTime = b.json.start || '';\n  const timePart = startTime.split(' ')[1] || '';\n  return {\n    json: {\n      phone: (cust.phone || '').replace('+', '').replace(' ', ''),\n      clientName: (cust.firstName || '') + ' ' + (cust.lastName || ''),\n      service: serv.name || '',\n      date: startTime.split(' ')[0] || '',\n      time: timePart.substring(0, 5),\n      businessName: 'Nails by Laura',\n      providerName: (prov.firstName || '') + ' ' + (prov.lastName || '')\n    }\n  };\n});"
        }
      },
      {
        "id": "check-empty",
        "name": "-+Hay turnos?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [
