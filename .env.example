# ============================================================
# TeToca — Variables de entorno (template)
# Copiar a .env y reemplazar los placeholders con valores reales
# NUNCA committear .env
# ============================================================

# --- Scheduler API ---
SCHEDULER_API_KEY=CAMBIAR_POR_VALOR_SEGURO_32_CHARS

# --- OpenWA (WhatsApp) ---
OPENWA_API_KEY=CAMBIAR_POR_VALOR_SEGURO_32_CHARS
API_MASTER_KEY=CAMBIAR_POR_VALOR_SEGURO_32_CHARS
OPENWA_SESSION_ID=CAMBIAR_SESSION_UUID

# --- n8n ---
N8N_WEBHOOK_TOKEN=CAMBIAR_POR_VALOR_SEGURO_32_CHARS
N8N_OWNER_PHONE=CAMBIAR_NUMERO_TELEFONO

# --- Admin Panel ---
ADMIN_PASSWORD_HASH=CAMBIAR_HASH_BCRYPT  # php -r "echo password_hash('tu_password', PASSWORD_BCRYPT);"

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_POR_VALOR_SEGURO_32_CHARS

# --- CORS ---
CORS_ORIGIN=http://localhost
