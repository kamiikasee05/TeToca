      {
        "id": "filter-future",
        "name": "Filtrar turnos futuros del cliente",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [
          1250,
          400
        ],
        "parameters": {
          "jsCode": "const customerId = $('Buscar cliente por tel+�fono').first().json[0].id;\nconst now = new Date().toISOString().replace('T', ' ').substring(0, 19);\n\nconst appointments = $input.all();\nconst future = appointments.filter(b => {\n  return b.json.customerId === customerId && b.json.start > now;\n});\n\nif (future.length === 0) {\n  return [{ json: { empty: true } }];\n}\nreturn future.map(b => ({\n  json: {\n    id: b.json.id,\n    start: b.json.start,\n    service: b.json.service?.name || '',\n    provider: (b.json.provider?.firstName || '') + ' ' + (b.json.provider?.lastName || '')\n  }\n}));"
        }
