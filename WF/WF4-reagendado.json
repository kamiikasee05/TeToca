      {
        "id": "find-appointment",
        "name": "Buscar turnos del cliente",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          1050,
          400
        ],
        "parameters": {
          "method": "GET",
          "url": "http://scheduler:3000/api/v1/appointments?with=customer,service,provider",
          "authentication": "genericCredentialType",
          "options": {},
          "genericAuthType": "httpBasicAuth",
          "headerParameters": {
            "parameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.SCHEDULER_API_KEY }}"
              }
            ]
          }
        },
        "credentials": {
          "httpBasicAuth": {
            "id": "g4JZy1RbupSK6sx9",
            "name": "EA Cred"
          }
        }
      },
      {
        "id": "filter-future",
        "name": "Filtrar turnos futuros del cliente",
        "type": "n8n-nodes-base.code",
        "typeVersion": 1,
        "position": [
          1250,
          400
        ],
        "parameters": {
          "jsCode": "const customerId = $('Buscar cliente por tel+�fono').first().json[0].id;\nconst now = new Date().toISOString().replace('T', ' ').substring(0, 19);\n\nconst appointments = $input.all();\nconst future = appointments.filter(b => {\n  return b.json.customerId === customerId && b.json.start > now;\n});\n\nif (future.length === 0) {\n  return [{ json: { empty: true } }];\n}\nreturn future.map(b => ({\n  json: {\n    id: b.json.id,\n    start: b.json.start,\n    service: b.json.service?.name || '',\n    provider: (b.json.provider?.firstName || '') + ' ' + (b.json.provider?.lastName || '')\n  }\n}));"
        }
      },
      {
        "id": "check-future",
        "name": "-+Turno futuro encontrado?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [
          1450,
          400
        ],
        "parameters": {
          "conditions": {
            "string": [
              {
                "value1": "={{ $json.empty }}",
                "operation": "isNotEmpty",
                "value2": ""
              }
            ]
          }
        }
      },
