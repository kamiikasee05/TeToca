      {
        "id": "check-keywords",
        "name": "-+Contiene CAMBIAR o REAGENDAR?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [
          450,
          300
        ],
        "parameters": {
          "conditions": {
            "string": [
              {
                "value1": "={{ $json.text }}",
                "operation": "contains",
                "value2": "CAMBIAR"
              },
              {
                "value1": "={{ $json.text }}",
                "operation": "contains",
                "value2": "REAGENDAR"
              }
            ],
            "combinator": "or"
          },
          "combineOperation": "any",
          "options": {
            "caseSensitive": false
          },
          "conditionsUi": {
            "and": [
              {
                "conditions": [
                  {
                    "id": "cond1",
                    "leftValue": "={{ $json.body }}",
                    "rightValue": "CAMBIAR",
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    },
                    "leftValueType": "value"
                  }
                ]
              },
              {
                "conditions": [
                  {
                    "id": "cond2",
                    "leftValue": "={{ $json.body }}",
                    "rightValue": "REAGENDAR",
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    },
                    "leftValueType": "value"
                  }
                ]
              }
            ]
          }
        }
      },
